# Copy this file to .env and fill in real secrets. Never commit .env.

SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-a-different-long-random-string

# Defaults to local SQLite so the app runs with zero setup.
# For MySQL use: mysql+pymysql://<user>:<password>@<host>/<db_name>
DATABASE_URL=sqlite:///smart_residential.db

# Comma separated list of origins allowed to call the /api/* JSON endpoints
# (your Angular/React app), e.g. http://localhost:4200,http://localhost:3000
CORS_ORIGINS=*

# Set to "true" only when serving the app over HTTPS in production
SESSION_COOKIE_SECURE=false
